#ifndef SLIM_COMMON_HTTP_ERROR_CODES_H
#define SLIM_COMMON_HTTP_ERROR_CODES_H

#include <cstdint>
#include <stdexcept>
#include <string>
#include <string_view>
#include <array>

#define SLIMCOMMONHTTP_VERSION  "@SLIMCOMMONHTTP_VERSION@"
#define SLIMCOMMONHTTP_GIT_HASH "@SLIMCOMMONHTTP_GIT_HASH@"

namespace slim::common::http {

enum class ErrorStatus : uint8_t {
    OK = 0,
    CookieDomainBareDot,
    CookieDomainEmpty,
    CookieDomainInvalidChar,
    CookieDomainLabelEmpty,
    CookieDomainLabelInvalidHyphen,
    CookieDomainLabelTooLong,
    CookieDomainNumericTld,
    CookieDomainTooLong,
    CookieDomainTrailingDot,
    CookieEmptyString,
    CookieExpiresInvalidFormat,
    CookieInvalidBoolean,
    CookieInvalidName,
    CookieInvalidValue,
    CookieMalformedMissingEquals,
    CookieMalformedPairMissingEquals,
    CookieMaxAgeEmpty,
    CookieMaxAgeExceedsLimit,
    CookieMaxAgeInvalidFormat,
    CookieMaxAgeTrailingChars,
    CookieNameEmpty,
    CookieNameHostPrefixHasDomain,
    CookieNameHostPrefixInvalidPath,
    CookieNameInvalidChar,
    CookieNamePrefixRequiresSecure,
    CookiePartitionedRequiresSameSiteNone,
    CookiePartitionedRequiresSecure,
    CookiePathInvalidChar,
    CookiePathMissingLeadingSlash,
    CookieSameSiteInvalid,
    CookieSameSiteNoneRequiresSecure,
    CookieTooLarge,
    CookieValueInvalidChar,
    CookieValueUnmatchedQuote,
    HeaderDelimiterInvalid,
    HeaderNameEmpty,
    HeaderNameInvalidChar,
    HeaderValueEmpty,
    HeaderValueInvalidChar,
    HeaderValueInvalidFolding,
    END
};

namespace error::status {
    constexpr std::array<std::string_view, static_cast<std::size_t>(ErrorStatus::END)> strings = {
        "OK",                                                                  // OK
        "Cookie domain cannot consist of a bare dot",                          // CookieDomainBareDot
        "Cookie domain name cannot be empty",                                  // CookieDomainEmpty
        "Cookie domain contains an invalid character",                         // CookieDomainInvalidChar
        "Cookie domain label cannot be empty",                                 // CookieDomainLabelEmpty
        "Cookie domain label has a hyphen in an invalid position",             // CookieDomainLabelInvalidHyphen
        "Cookie domain label exceeds the maximum allowed length",              // CookieDomainLabelTooLong
        "Cookie domain's top-level domain (TLD) must not be numeric",          // CookieDomainNumericTld
        "Cookie domain name exceeds the maximum allowed length",               // CookieDomainTooLong
        "Cookie domain name must not end with a trailing dot",                 // CookieDomainTrailingDot
        "Cookie string cannot be empty",                                       // CookieEmptyString
        "Cookie Expires attribute has an invalid date format",                 // CookieExpiresInvalidFormat
        "Cookie attribute contains an invalid boolean value",                  // CookieInvalidBoolean
        "Cookie name failed validation",                                       // CookieInvalidName
        "Cookie value failed validation",                                      // CookieInvalidValue
        "Cookie is missing a '=' separator",                                   // CookieMalformedMissingEquals
        "Cookie pair is missing a '=' separator",                              // CookieMalformedPairMissingEquals
        "Cookie Max-Age attribute cannot be empty",                            // CookieMaxAgeEmpty
        "Cookie Max-Age value exceeds the maximum allowed limit",              // CookieMaxAgeExceedsLimit
        "Cookie Max-Age attribute has an invalid format",                      // CookieMaxAgeInvalidFormat
        "Cookie Max-Age value has unexpected trailing characters",             // CookieMaxAgeTrailingChars
        "Cookie name cannot be empty",                                         // CookieNameEmpty
        "Cookie __Host- prefix cannot be combined with a Domain attribute",    // CookieNameHostPrefixHasDomain
        "Cookie __Host- prefix requires the Path attribute to be '/'",         // CookieNameHostPrefixInvalidPath
        "Cookie name contains an invalid character",                           // CookieNameInvalidChar
        "Cookie name prefix requires the Secure attribute",                    // CookieNamePrefixRequiresSecure
        "Partitioned cookies require SameSite=None",                           // CookiePartitionedRequiresSameSiteNone
        "Partitioned cookies require the Secure attribute",                    // CookiePartitionedRequiresSecure
        "Cookie path contains an invalid character",                           // CookiePathInvalidChar
        "Cookie path must begin with a forward slash ('/')",                   // CookiePathMissingLeadingSlash
        "Cookie SameSite attribute has an invalid value",                      // CookieSameSiteInvalid
        "Cookie SameSite=None requires the Secure attribute",                  // CookieSameSiteNoneRequiresSecure
        "Cookie exceeds the maximum allowed size",                             // CookieTooLarge
        "Cookie value contains an invalid character",                          // CookieValueInvalidChar
        "Cookie value has an unmatched quotation mark",                        // CookieValueUnmatchedQuote
        "Header contains an invalid delimiter",                                // HeaderDelimiterInvalid
        "Header name cannot be empty",                                         // HeaderNameEmpty
        "Header name contains an invalid character",                           // HeaderNameInvalidChar
        "Header value cannot be empty",                                        // HeaderValueEmpty
        "Header value contains an invalid character",                          // HeaderValueInvalidChar
        "Header value contains obsolete line folding (obs-fold)"               // HeaderValueInvalidFolding
    };

    [[nodiscard]] constexpr std::string_view to_string(ErrorStatus status) noexcept {
        const auto index = static_cast<std::size_t>(status);
        if (index < strings.size()) return strings[index];
        return "Unknown";
    }
}

class HttpException : public std::logic_error {
public:
    explicit HttpException(ErrorStatus e)
        : std::logic_error(std::string{error::status::to_string(e)}), status(e) {}

        explicit HttpException(std::string msg) : std::logic_error(msg) {}

    ErrorStatus error() const noexcept { return status; }
private:
    ErrorStatus status = ErrorStatus::OK;
};


} // namespace slim::common::http

#endif // SLIM_COMMON_HTTP_ERROR_CODES_H
